{
  "name": "kirin",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@apollo/client": "^3.7.14",
    "@emotion/react": "11.11.0",
    "@emotion/styled": "11.11.0",
    "@material/web": "^1.0.0-pre.8",
    "@mui/icons-material": "5.11.16",
    "@mui/material": "5.13.2",
    "@mui/styled-engine-sc": "5.12.0",
    "bencode": "3.0.3",
    "graphql": "16.6.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.11.2",
    "styled-components": "^6.0.0-rc.2",
    "valtio": "1.10.5"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^4.0.0",
    "@graphql-codegen/client-preset": "^4.0.0",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@testing-library/user-event": "13.5.0",
    "@types/jest": "27.5.2",
    "@types/node": "16.18.32",
    "@types/react": "18.2.7",
    "@types/react-dom": "18.2.4",
    "@types/styled-components": "^5.1.26",
    "@typescript-eslint/eslint-plugin": "^5.59.7",
    "@typescript-eslint/parser": "^5.59.7",
    "eslint": "^8.41.0",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.32.2",
    "graphql-faker": "^2.0.0-rc.25",
    "react-scripts": "5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4",
    "web-vitals": "2.1.4"
  },
  "config": {
    "graphql": "../raizekusu/src/main/resources/graphql/*",
    "aggregation": "src/generated/graphql/all.graphql"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "graphql:generate": "yarn graphql-code-generator --config ./codegen.ts",
    "graphql:mock": "cat $npm_package_config_graphql > $npm_package_config_aggregation && graphql-faker --co 'http://localhost:3000' $npm_package_config_aggregation",
    "lint": "eslint -c .eslintrc.json 'src/**/*.tsx'",
    "lint:fix": "eslint -c .eslintrc.json --fix 'src/**/*.tsx'",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
